dist/
.astro/

# Dependencies
node_modules/

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Environment
.env
.env.production

# OS/IDE
.DS_Store
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.pyc
