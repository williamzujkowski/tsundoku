---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Tsundoku — a curated bookshelf of 3,526 essential works" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Tsundoku</title>
  </head>
  <body class="min-h-screen">
    <nav class="border-b border-gray-800 bg-gray-900/80 backdrop-blur-sm sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="text-lg font-semibold tracking-tight text-white hover:text-purple-400 transition-colors">
            積ん読 Tsundoku
          </a>
          <div class="flex items-center gap-4">
            <a href="/browse" class="text-sm text-gray-400 hover:text-white transition-colors">Browse</a>
            <a href="/categories" class="text-sm text-gray-400 hover:text-white transition-colors">Categories</a>
            <a href="/authors" class="text-sm text-gray-400 hover:text-white transition-colors">Authors</a>
          </div>
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <slot />
    </main>
    <footer class="border-t border-gray-800 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        <p>3,526 essential works across 42 categories — because buying books and not reading them is a lifestyle.</p>
        <a href="https://github.com/williamzujkowski/tsundoku" class="text-gray-400 hover:text-white transition-colors mt-2 inline-block">Source on GitHub</a>
      </div>
    </footer>
  </body>
</html>
