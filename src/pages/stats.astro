---
import fs from 'node:fs/promises';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import stats from '../data/stats.json';
import { getCollection } from 'astro:content';
import { toSlug } from '../utils/formatting';

const base = import.meta.env.BASE_URL;

// Country code → nationality (matches the author detail page mapping)
const COUNTRY_NAMES: Record<string, string> = {
  GB: 'British', US: 'American', CA: 'Canadian', AU: 'Australian', NZ: 'New Zealander',
  IE: 'Irish', FR: 'French', DE: 'German', IT: 'Italian', ES: 'Spanish',
  PT: 'Portuguese', NL: 'Dutch', BE: 'Belgian', CH: 'Swiss', AT: 'Austrian',
  SE: 'Swedish', NO: 'Norwegian', DK: 'Danish', FI: 'Finnish', IS: 'Icelandic',
  RU: 'Russian', PL: 'Polish', CZ: 'Czech', HU: 'Hungarian', GR: 'Greek',
  RO: 'Romanian', BG: 'Bulgarian', HR: 'Croatian', RS: 'Serbian', UA: 'Ukrainian',
  TR: 'Turkish', JP: 'Japanese', CN: 'Chinese', KR: 'Korean', IN: 'Indian',
  IL: 'Israeli', IR: 'Iranian', EG: 'Egyptian', ZA: 'South African', NG: 'Nigerian',
  BR: 'Brazilian', AR: 'Argentine', CL: 'Chilean', MX: 'Mexican', CO: 'Colombian',
  PE: 'Peruvian',
};
function nationalityLabel(code: string): string {
  return COUNTRY_NAMES[code] ?? code;
}

const nationalityMax = Math.max(1, ...stats.nationality_distribution.map(n => n.count));

// Timeline: show decades with at least 1 book, and only post-1700 to keep
// the chart readable (BCE/medieval/early-modern entries are too sparse for
// a comparative bar chart and would dwarf-the-rest visually).
const timelineEntries = stats.timeline.filter(t => t.decade >= 1700);
const timelineMax = Math.max(1, ...timelineEntries.map(t => t.count));

// Avoid `<` inside JSX expressions — the .astro parser misreads it as a tag
// opener even inside braces. Pre-format the oldest-year line in the script.
const oldestYearLine = stats.oldest_year !== undefined && stats.oldest_year !== null
  ? (stats.oldest_year < 0
      ? `Oldest entry: ${Math.abs(stats.oldest_year)} BCE.`
      : `Oldest entry: ${stats.oldest_year}.`)
  : '';

// Full per-country book counts for the world map. Aggregates from the
// authors collection at build time.
const allBooks = await getCollection('books');
const allAuthors = await getCollection('authors');
const authorPrimaryNat = new Map<string, string>();
for (const a of allAuthors) {
  const nats = a.data.nationality ?? [];
  if (nats.length > 0) authorPrimaryNat.set(a.data.name, nats[0]);
}
const countryBookCounts: Record<string, number> = {};
for (const b of allBooks) {
  const nat = authorPrimaryNat.get(b.data.author);
  if (nat) countryBookCounts[nat] = (countryBookCounts[nat] ?? 0) + 1;
}
const mapMax = Math.max(1, ...Object.values(countryBookCounts));

const worldMapSvg = await fs.readFile(
  path.resolve(process.cwd(), 'src/data/world-map.svg'),
  'utf-8',
);

// sqrt scale for perceptually-uniform book-count gradient.
// Emit a percentage that the CSS color-mix consumes — the actual colors
// are theme-aware (--map-low / --map-high in src/styles/global.css), so
// the same fill rules adapt to dark and light without rebuilding the
// stats page.
function mixPercent(count: number): number {
  return Math.round(Math.sqrt(count / mapMax) * 100);
}
const mapFillRules = Object.entries(countryBookCounts)
  .map(([code, count]) => `.world-map path[data-country="${code}"] { fill: color-mix(in oklch, var(--map-low), var(--map-high) ${mixPercent(count)}%); }`)
  .join('\n');

// Wrap the dynamic CSS in a <style> tag for set:html injection.
const mapStyleBlock = `<style>
.world-map { width: 100%; height: auto; max-width: 900px; margin: 0 auto; display: block; }
.world-map path { fill: var(--bg-elevated); stroke: var(--border); stroke-width: 0.4; transition: fill 200ms ease; }
.world-map path:hover { stroke-width: 1.2; stroke: var(--text-muted); }
.timeline-bars { display: grid; grid-template-columns: repeat(auto-fit, minmax(48px, 1fr)); gap: 4px; align-items: end; min-height: 160px; }
.timeline-bar-wrap { display: flex; flex-direction: column; align-items: center; gap: 4px; }
.timeline-bar-fill { width: 100%; background: var(--pop-purple); min-height: 2px; }
${mapFillRules}
</style>`;
---

<Layout title="Stats" description="How deep does the pile go? Numbers on the unread backlog.">
  <h1 class="heading-xl mb-6">The Damage</h1>

  <!-- Overview cards -->
  <div class="grid grid-2 sm-grid-4 gap-3 mb-8">
    <div class="stat-badge">
      <p class="stat-badge-number">{stats.total_books.toLocaleString()}</p>
      <p class="stat-badge-label">Books</p>
    </div>
    <div class="stat-badge">
      <p class="stat-badge-number">{stats.total_categories}</p>
      <p class="stat-badge-label">Categories</p>
    </div>
    <div class="stat-badge">
      <p class="stat-badge-number">{stats.total_authors.toLocaleString()}</p>
      <p class="stat-badge-label">Authors</p>
    </div>
    <div class="stat-badge stat-badge-pop">
      <p class="stat-badge-number">{stats.priorities.must_read.toLocaleString()}</p>
      <p class="stat-badge-label">Must-Reads</p>
    </div>
  </div>

  <!-- Bookshelf fun stats -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">By the Numbers</h2>
    <div class="grid grid-2 sm-grid-4 gap-3">
      <div class="stat-badge">
        <p class="stat-badge-number">{stats.bookshelf.total_pages.toLocaleString()}</p>
        <p class="stat-badge-label">Total pages</p>
      </div>
      <div class="stat-badge">
        <p class="stat-badge-number">{stats.bookshelf.estimated_reading_hours.toLocaleString()}</p>
        <p class="stat-badge-label">Hours to read all</p>
      </div>
      <div class="stat-badge">
        <p class="stat-badge-number">{stats.bookshelf.shelf_meters}m</p>
        <p class="stat-badge-label">Of shelf space</p>
      </div>
      <div class="stat-badge">
        <p class="stat-badge-number">{Math.round(stats.bookshelf.estimated_reading_hours / 24 / 365 * 10) / 10}</p>
        <p class="stat-badge-label">Years nonstop reading</p>
      </div>
    </div>
  </section>

  <!-- Decade timeline — every 10-year slice with at least one book -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">When the Books Are From</h2>
    <p class="text-sm text-muted mb-4">By first-edition decade. {oldestYearLine} Pre-1700 entries omitted from the chart for legibility — see the era table below.</p>
    <div class="card card-padded-lg">
      <div class="timeline-bars">
        {timelineEntries.map(t => {
          const heightPct = (t.count / timelineMax) * 100;
          return (
            <div class="timeline-bar-wrap" title={`${t.decade}s: ${t.count} books`}>
              <span class="text-xs text-dim text-mono">{t.count}</span>
              <div
                class="timeline-bar-fill"
                style={`height: ${Math.max(heightPct, 2)}%`}
                aria-hidden="true">
              </div>
              <span class="text-xs text-dim text-mono">{String(t.decade).slice(-2)}</span>
            </div>
          );
        })}
      </div>
      <p class="text-xs text-dim mt-3">Each bar is a decade; the two-digit label is the decade's tens digit (e.g. "49" = 1940s).</p>
    </div>
  </section>

  <!-- Author nationality distribution + map -->
  {stats.nationality_distribution && stats.nationality_distribution.length > 0 && (
    <section class="mb-8">
      <h2 class="heading-md mb-4">Where the Authors Are From</h2>
      <p class="text-sm text-muted mb-4">Books by primary nationality of their author ({stats.author_enrichment.nationality} of {stats.author_enrichment.total_authors} authors enriched via Wikidata so far).</p>

      <Fragment set:html={mapStyleBlock} />

      <div class="card card-padded-lg mb-4">
        <Fragment set:html={worldMapSvg} />
      </div>

      <div class="card card-padded-lg">
        {stats.nationality_distribution.map(n => (
          <div class="mb-2">
            <div class="flex justify-between text-sm mb-2">
              <span class="text-muted">{nationalityLabel(n.code)}</span>
              <span class="text-dim text-mono">{n.count}</span>
            </div>
            <div class="progress-bar" role="progressbar" aria-valuenow={Math.round(100 * n.count / nationalityMax)} aria-valuemin="0" aria-valuemax="100" aria-label={`${nationalityLabel(n.code)}: ${n.count} books`}>
              <div style={`width: ${100 * n.count / nationalityMax}%; background: var(--pop-cyan);`}></div>
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Reading progress — binary: read or not -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">Reading Progress</h2>
    <div class="grid grid-2 gap-3 mb-4 max-w-xl">
      <div class="stat-badge stat-badge-green">
        <p class="stat-badge-number">{stats.reading_progress.read.toLocaleString()}</p>
        <p class="stat-badge-label">Read</p>
      </div>
      <div class="stat-badge stat-badge-pop">
        <p class="stat-badge-number">{(stats.total_books - stats.reading_progress.read).toLocaleString()}</p>
        <p class="stat-badge-label">Not yet</p>
      </div>
    </div>
    <div class="card card-padded">
      <div class="progress-bar" role="progressbar" aria-valuenow={Math.round(100 * stats.reading_progress.read / stats.total_books)} aria-valuemin="0" aria-valuemax="100" aria-label={`${Math.round(100 * stats.reading_progress.read / stats.total_books)}% of books read`}>
        <div class="progress-fill-read" style={`width: ${100 * stats.reading_progress.read / stats.total_books}%`}></div>
      </div>
      <p class="text-xs text-dim mt-2">
        {stats.reading_progress.read.toLocaleString()} of {stats.total_books.toLocaleString()} read ({Math.round(100 * stats.reading_progress.read / stats.total_books)}%). The time spent tracking the other {(stats.total_books - stats.reading_progress.read).toLocaleString()} could have been spent reading them.
      </p>
    </div>
  </section>

  <!-- Priority breakdown -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">Priority Breakdown</h2>
    <div class="card card-padded-lg">
      {[
        { label: 'Must-Read', count: stats.priorities.must_read, color: 'var(--pop-pink)' },
        { label: 'Recommended', count: stats.priorities.recommended, color: 'var(--text-muted)' },
        { label: 'Eventually', count: stats.priorities.supplementary, color: 'var(--text-dim)' },
      ].map(p => (
        <div class="mb-4">
          <div class="flex justify-between text-sm mb-2">
            <span class="text-muted">{p.label}</span>
            <span class="text-dim">{p.count} ({Math.round(100 * p.count / stats.total_books)}%)</span>
          </div>
          <div class="progress-bar" role="progressbar" aria-valuenow={Math.round(100 * p.count / stats.total_books)} aria-valuemin="0" aria-valuemax="100" aria-label={`${p.label}: ${p.count} books`}>
            <div style={`width: ${100 * p.count / stats.total_books}%; background: ${p.color};`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Enrichment coverage — books -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">Book Data Coverage</h2>
    <div class="grid grid-2 md-grid-3 gap-3">
      {[
        { label: 'Cover Art', pct: stats.enrichment.covers_pct, count: stats.enrichment.covers },
        { label: 'Descriptions', pct: stats.enrichment.descriptions_pct, count: stats.enrichment.descriptions },
        { label: 'ISBNs', pct: stats.enrichment.isbns_pct, count: stats.enrichment.isbns },
        { label: 'Page Counts', pct: stats.enrichment.pages_pct, count: stats.enrichment.pages },
        { label: 'Pub. Years', pct: Math.round(100 * stats.enrichment.years / stats.total_books), count: stats.enrichment.years },
        { label: 'DDC Class.', pct: Math.round(100 * (stats.enrichment.ddc ?? 0) / stats.total_books), count: stats.enrichment.ddc ?? 0 },
        { label: 'LCC Class.', pct: Math.round(100 * (stats.enrichment.lcc ?? 0) / stats.total_books), count: stats.enrichment.lcc ?? 0 },
        { label: 'Wikidata Linked', pct: Math.round(100 * (stats.enrichment.wikidata ?? 0) / stats.total_books), count: stats.enrichment.wikidata ?? 0 },
        { label: 'Awards', pct: Math.round(100 * (stats.enrichment.awards ?? 0) / stats.total_books), count: stats.enrichment.awards ?? 0 },
      ].map(e => (
        <div class="card card-padded">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm text-muted">{e.label}</span>
            <span class="font-bold heading-md">{e.pct}%</span>
          </div>
          <div class="progress-bar" role="progressbar" aria-valuenow={e.pct} aria-valuemin="0" aria-valuemax="100" aria-label={`${e.label} coverage: ${e.pct}%`}>
            <div style={`width: ${e.pct}%; background: var(--pop-pink);`}></div>
          </div>
          <p class="text-xs text-dim mt-2">{e.count.toLocaleString()} of {stats.total_books.toLocaleString()}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Author data coverage -->
  {stats.author_enrichment && (
    <section class="mb-8">
      <h2 class="heading-md mb-4">Author Data Coverage</h2>
      <div class="grid grid-2 md-grid-3 gap-3">
        {[
          { label: 'Wikidata Linked', count: stats.author_enrichment.wikidata },
          { label: 'Nationality', count: stats.author_enrichment.nationality },
          { label: 'VIAF ID', count: stats.author_enrichment.viaf },
          { label: 'Awards', count: stats.author_enrichment.awards },
          { label: 'Movements', count: stats.author_enrichment.movements },
          { label: 'Pen Names', count: stats.author_enrichment.alternate_names },
        ].map(e => {
          const pct = Math.round(100 * e.count / stats.author_enrichment.total_authors);
          return (
            <div class="card card-padded">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm text-muted">{e.label}</span>
                <span class="font-bold heading-md">{pct}%</span>
              </div>
              <div class="progress-bar" role="progressbar" aria-valuenow={pct} aria-valuemin="0" aria-valuemax="100" aria-label={`${e.label} coverage: ${pct}%`}>
                <div style={`width: ${pct}%; background: var(--pop-cyan);`}></div>
              </div>
              <p class="text-xs text-dim mt-2">{e.count.toLocaleString()} of {stats.author_enrichment.total_authors.toLocaleString()}</p>
            </div>
          );
        })}
      </div>
    </section>
  )}

  <!-- Year distribution -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">Publication Era</h2>
    <div class="card card-padded-lg">
      <p class="text-sm text-muted mb-4">Spanning from {stats.oldest_year} to {stats.newest_year}</p>
      {[
        { label: 'Before 1800', count: stats.year_distribution.before_1800 },
        { label: '1800\u20131899', count: stats.year_distribution['1800_1899'] },
        { label: '1900\u20131949', count: stats.year_distribution['1900_1949'] },
        { label: '1950\u20131999', count: stats.year_distribution['1950_1999'] },
        { label: '2000+', count: stats.year_distribution['2000_plus'] },
      ].map(era => (
        <div class="mb-2">
          <div class="flex justify-between text-sm mb-2">
            <span class="text-muted">{era.label}</span>
            <span class="text-dim">{era.count}</span>
          </div>
          <div class="progress-bar" role="progressbar" aria-valuenow={Math.round(100 * era.count / stats.total_books)} aria-valuemin="0" aria-valuemax="100" aria-label={`${era.label}: ${era.count} books`}>
            <div style={`width: ${100 * era.count / stats.total_books}%; background: var(--pop-purple);`}></div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Top authors -->
  <section class="mb-8">
    <h2 class="heading-md mb-4">Most Represented Authors</h2>
    <div class="grid sm-grid-2 gap-2">
      {stats.top_authors.map((a: {name: string; count: number}, i: number) => {
        const colors = ['var(--pop-pink)', 'var(--pop-blue)', 'var(--pop-green)', 'var(--pop-orange)', 'var(--pop-purple)', 'var(--pop-cyan)', 'var(--pop-yellow)', 'var(--pop-red)'];
        const color = colors[i % colors.length];
        return (
          <a href={`${base}authors/${toSlug(a.name)}/`}
             class="list-item card-accent-left" style={`--accent-color: ${color};`}>
            <span class="step-number" style={`color: ${color};`}>{i + 1}</span>
            <span class="text-sm font-bold">{a.name}</span>
            <span class="text-xs text-mono ml-auto" style={`color: ${color};`}>{a.count}</span>
          </a>
        );
      })}
    </div>
  </section>

  <p class="text-xs text-dim mt-2">
    Snapshot as of {new Date(stats.generated_at).toLocaleDateString()}. The pile has probably grown since then.
  </p>
</Layout>
