---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const categoryMap = new Map<string, number>();

for (const book of books) {
  const cat = book.data.category;
  categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}

const categories = [...categoryMap.entries()]
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, count]) => ({
    name,
    count,
    slug: name.toLowerCase().replace(/[^a-z0-9]+/g, '-'),
  }));
const base = import.meta.env.BASE_URL;
---

<Layout title="Categories">
  <h1 class="text-3xl font-bold text-white mb-2">Categories</h1>
  <p class="text-gray-400 mb-8">{categories.length} categories across the collection.</p>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
    {categories.map(cat => (
      <a href={`${base}categories/${cat.slug}/`}
         class="rounded-xl border border-gray-800 bg-gray-900 p-5 hover:border-purple-800 transition-colors">
        <h2 class="text-white font-semibold mb-1">{cat.name}</h2>
        <p class="text-gray-500 text-sm">{cat.count} {cat.count === 1 ? 'book' : 'books'}</p>
      </a>
    ))}
  </div>
</Layout>
