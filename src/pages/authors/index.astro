---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const authorMap = new Map<string, number>();

for (const book of books) {
  const author = book.data.author;
  authorMap.set(author, (authorMap.get(author) ?? 0) + 1);
}

const authors = [...authorMap.entries()]
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, count]) => ({ name, count }));

const letters = [...new Set(authors.map(a => a.name[0].toUpperCase()))].sort();
---

<Layout title="Authors">
  <h1 class="text-3xl font-bold text-white mb-2">Authors</h1>
  <p class="text-gray-400 mb-8">{authors.length} authors in the collection.</p>

  <!-- Letter navigation -->
  <div class="flex flex-wrap gap-1 mb-8">
    {letters.map(letter => (
      <a href={`#${letter}`}
         class="w-8 h-8 flex items-center justify-center rounded bg-gray-800 text-gray-400 hover:bg-purple-900 hover:text-purple-300 text-sm transition-colors">
        {letter}
      </a>
    ))}
  </div>

  {letters.map(letter => {
    const letterAuthors = authors.filter(a => a.name[0].toUpperCase() === letter);
    return (
      <section id={letter} class="mb-8">
        <h2 class="text-lg font-bold text-purple-400 mb-3 sticky top-14 bg-[#1C1B1F] py-2 z-10">{letter}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-2">
          {letterAuthors.map(author => (
            <div class="rounded-lg border border-gray-800 bg-gray-900 px-4 py-3 flex justify-between items-center">
              <span class="text-white text-sm">{author.name}</span>
              <span class="text-gray-500 text-xs">{author.count}</span>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
