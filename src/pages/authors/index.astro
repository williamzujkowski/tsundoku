---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const books = await getCollection('books');
const authorMap = new Map<string, number>();

for (const book of books) {
  const author = book.data.author;
  authorMap.set(author, (authorMap.get(author) ?? 0) + 1);
}

const authors = [...authorMap.entries()]
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([name, count]) => ({ name, count }));

const letters = [...new Set(authors.map(a => a.name[0].toUpperCase()))].sort();
---

<Layout title="Authors" description={`${authors.length} authors in the tsundoku collection`}>
  <h1 class="text-2xl sm:text-3xl font-bold text-white mb-2">Authors</h1>
  <p class="text-gray-400 text-sm sm:text-base mb-6 sm:mb-8">{authors.length.toLocaleString()} authors in the collection.</p>

  <!-- Letter navigation -->
  <nav aria-label="Jump to letter" class="flex flex-wrap gap-1.5 mb-6 sm:mb-8">
    {letters.map(letter => (
      <a href={`#${letter}`}
         class="w-10 h-10 sm:w-8 sm:h-8 flex items-center justify-center rounded-lg sm:rounded bg-gray-800 text-gray-400 hover:bg-purple-900 hover:text-purple-300 text-sm font-medium transition-colors">
        {letter}
      </a>
    ))}
  </nav>

  {letters.map(letter => {
    const letterAuthors = authors.filter(a => a.name[0].toUpperCase() === letter);
    return (
      <section id={letter} class="mb-6 sm:mb-8">
        <h2 class="text-lg font-bold text-purple-400 mb-3 sticky top-[3.5rem] bg-[#1C1B1F] py-2 z-10 border-b border-gray-800/50">{letter}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-2">
          {letterAuthors.map(author => (
            <div class="rounded-lg border border-gray-800 bg-gray-900 px-4 py-3 flex justify-between items-center hover:border-purple-800/40 transition-colors">
              <span class="text-white text-sm">{author.name}</span>
              <span class="text-gray-500 text-xs ml-2 shrink-0">{author.count} {author.count === 1 ? 'book' : 'books'}</span>
            </div>
          ))}
        </div>
      </section>
    );
  })}
</Layout>
