---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import BookGrid from '../components/BookGrid.svelte';

const base = import.meta.env.BASE_URL;
const books = await getCollection('books');
const categories = [...new Set(books.map(b => b.data.category))].sort();
const bookData = books.map(b => b.data);
---

<Layout title="Browse">
  <h1 class="text-2xl sm:text-3xl font-bold text-white mb-4 sm:mb-6">Browse Books</h1>
  <BookGrid client:load books={bookData} categories={categories} baseUrl={base} />
</Layout>
