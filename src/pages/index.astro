---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import stats from '../data/stats.json';
import { toSlug, seededShuffle } from '../utils/formatting';

const base = import.meta.env.BASE_URL;
const books = await getCollection('books');
const categories = [...new Set(books.map(b => b.data.category))].sort();
---

<Layout title="Home">
  <section class="text-center py-12 sm:py-20">
    <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight mb-4 bg-gradient-to-r from-white via-purple-200 to-purple-400 bg-clip-text text-transparent">
      積ん読
    </h1>
    <p class="text-lg sm:text-xl text-purple-400 mb-2">Tsundoku</p>
    <p class="text-gray-400 text-base sm:text-lg mb-8 max-w-xl mx-auto px-4">
      A curated collection of {stats.total_books.toLocaleString()} essential works across {stats.total_categories} categories from {stats.total_authors.toLocaleString()} authors.
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-6 max-w-lg sm:max-w-2xl mx-auto mb-10">
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-3 sm:p-4">
        <p class="text-2xl sm:text-3xl font-bold text-white">{stats.total_books.toLocaleString()}</p>
        <p class="text-xs sm:text-sm text-gray-500">Books</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-3 sm:p-4">
        <p class="text-2xl sm:text-3xl font-bold text-white">{stats.total_categories}</p>
        <p class="text-xs sm:text-sm text-gray-500">Categories</p>
      </div>
      <div class="rounded-xl border border-gray-800 bg-gray-900 p-3 sm:p-4">
        <p class="text-2xl sm:text-3xl font-bold text-white">{stats.total_authors.toLocaleString()}</p>
        <p class="text-xs sm:text-sm text-gray-500">Authors</p>
      </div>
      <div class="rounded-xl border border-purple-800/50 bg-purple-950/20 p-3 sm:p-4">
        <p class="text-2xl sm:text-3xl font-bold text-purple-400">{stats.priorities.must_read.toLocaleString()}</p>
        <p class="text-xs sm:text-sm text-gray-500">Must-Reads</p>
      </div>
    </div>
    <a href={`${base}browse/`} class="inline-flex items-center justify-center rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-semibold px-6 sm:px-8 py-3 transition-colors shadow-lg shadow-purple-900/30">
      Browse the Collection
    </a>
  </section>

  {/* Featured Must-Reads */}
  {(() => {
    const mustReads = books.filter(b => b.data.priority === 1 && b.data.cover_url);
    const featured = seededShuffle(mustReads).slice(0, 8);
    return featured.length > 0 ? (
      <section class="py-8 sm:py-12">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-4 sm:mb-6">Featured Must-Reads</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3 sm:gap-4">
          {featured.map(b => (
            <a href={`${base}books/${b.data.slug}/`} class="group text-center">
              <div class="overflow-hidden rounded-lg mb-2 border border-gray-800 group-hover:border-purple-700/50 transition-all duration-200 group-hover:shadow-lg group-hover:shadow-purple-900/30">
                <img src={b.data.cover_url_large || b.data.cover_url} alt={b.data.title}
                  class="w-full aspect-[2/3] object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              </div>
              <p class="text-white text-xs font-medium line-clamp-2 group-hover:text-purple-200 transition-colors">{b.data.title}</p>
              <p class="text-gray-500 text-[10px] truncate">{b.data.author}</p>
            </a>
          ))}
        </div>
      </section>
    ) : null;
  })()}

  <section class="py-8 sm:py-12">
    <h2 class="text-xl sm:text-2xl font-bold text-white mb-4 sm:mb-6">Categories</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-6 gap-2 sm:gap-3">
      {categories.map(cat => {
        const count = books.filter(b => b.data.category === cat).length;
        return (
          <a href={`${base}categories/${toSlug(cat)}/`}
             class="flex items-center justify-between sm:flex-col sm:text-center rounded-xl border border-gray-800 bg-gray-900 px-4 py-3 sm:p-4 hover:border-purple-800 transition-colors group">
            <p class="text-white font-medium text-sm group-hover:text-purple-300 transition-colors">{cat}</p>
            <p class="text-gray-500 text-xs sm:mt-1">{count} books</p>
          </a>
        );
      })}
    </div>
  </section>
</Layout>
