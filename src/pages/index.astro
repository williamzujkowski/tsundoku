---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import stats from '../data/stats.json';
import { toSlug, seededShuffle } from '../utils/formatting';

const base = import.meta.env.BASE_URL;
const books = await getCollection('books');

const readPct = Math.round(100 * stats.reading_progress.read / stats.total_books);
const yearsToFinish = Math.round(stats.bookshelf.estimated_reading_hours / 8 / 365 * 10) / 10;
const yearSpan = stats.newest_year - stats.oldest_year;
---

<Layout title="Home">
  <!-- Hero -->
  <section class="py-12 text-center">
    <h1 class="heading-xl mb-2">積ん読</h1>
    <p class="hero-subtitle text-mono">TSUNDOKU</p>
    <p class="text-muted mb-4 max-w-xl mx-auto">
      Everything I've read or want to read. Not meticulously curated — just a lifelong habit of
      accumulating books faster than I can finish them.
    </p>
    <p class="text-dim text-xs text-mono mb-8 max-w-xl mx-auto">
      {stats.total_books.toLocaleString()} books · {stats.total_authors.toLocaleString()} authors ·
      {yearSpan.toLocaleString()} years of human thought, mostly unread
    </p>

    <!-- Stat Badges -->
    <div class="grid grid-2 sm-grid-4 gap-4 max-w-2xl mx-auto mb-8">
      <div class="stat-badge">
        <div class="stat-badge-number">{stats.total_books.toLocaleString()}</div>
        <div class="stat-badge-label">Books</div>
      </div>
      <div class="stat-badge">
        <div class="stat-badge-number">{stats.total_categories}</div>
        <div class="stat-badge-label">Categories</div>
      </div>
      <div class="stat-badge">
        <div class="stat-badge-number">{stats.total_authors.toLocaleString()}</div>
        <div class="stat-badge-label">Authors</div>
      </div>
      <div class="stat-badge stat-badge-pop">
        <div class="stat-badge-number">{stats.reading_progress.read.toLocaleString()}</div>
        <div class="stat-badge-label">Read</div>
      </div>
    </div>

    <!-- Progress -->
    {stats.reading_progress.read > 0 && (
      <div class="max-w-xl mx-auto mb-8">
        <div class="progress-bar">
          <div class="progress-fill-read" style={`width: ${readPct}%`}></div>
          <div class="progress-fill-reading" style={`width: ${100 * stats.reading_progress.reading / stats.total_books}%`}></div>
        </div>
        <p class="text-xs text-dim text-mono mt-2">
          {readPct}% read · {stats.reading_progress.want} on the pile ·
          {yearsToFinish} years to finish at this pace
        </p>
      </div>
    )}

    <a href={`${base}browse/`} class="btn">Browse the Pile</a>
  </section>

  <!-- By the Numbers -->
  <hr class="section-divider" />
  <section class="py-8">
    <h2 class="heading-md mb-6">By the Numbers</h2>
    <div class="grid grid-2 sm-grid-4 gap-4">
      <div class="stat-badge">
        <div class="stat-badge-number">{(stats.bookshelf.total_pages / 1000000).toFixed(1)}M</div>
        <div class="stat-badge-label">Total Pages</div>
        <div class="stat-badge-sub">{Math.round(stats.bookshelf.shelf_meters)}m of shelf</div>
      </div>
      <div class="stat-badge">
        <div class="stat-badge-number">{stats.bookshelf.estimated_reading_hours.toLocaleString()}</div>
        <div class="stat-badge-label">Reading Hours</div>
        <div class="stat-badge-sub">{(stats.bookshelf.estimated_reading_hours / 24 / 365).toFixed(1)} years nonstop</div>
      </div>
      <div class="stat-badge">
        <div class="stat-badge-number">{Math.abs(stats.oldest_year)} BC</div>
        <div class="stat-badge-label">Oldest Work</div>
        <div class="stat-badge-sub">{yearSpan.toLocaleString()} year range</div>
      </div>
      <div class="stat-badge stat-badge-pop">
        <div class="stat-badge-number">{stats.reading_progress.want}</div>
        <div class="stat-badge-label">Want to Read</div>
        <div class="stat-badge-sub">the pile grows</div>
      </div>
    </div>
  </section>

  <!-- Featured Must-Reads -->
  {(() => {
    const mustReads = books.filter(b => b.data.priority === 1 && b.data.cover_url);
    const featured = seededShuffle(mustReads).slice(0, 8);
    return featured.length > 0 ? (
      <>
        <hr class="section-divider" />
        <section class="py-8">
          <h2 class="heading-md mb-6">Must-Reads (Allegedly)</h2>
          <div class="grid grid-2 sm-grid-4 lg-grid-8 gap-4">
            {featured.map(b => (
              <a href={`${base}books/${b.data.slug}/`} class="book-cover-group" style="text-decoration: none;">
                <img src={b.data.cover_url_large || b.data.cover_url} alt={b.data.title}
                  class="book-cover" loading="lazy" />
                <p class="line-clamp-2" style="font-size: 0.75rem; font-weight: 600; margin-top: 0.5rem; color: var(--text);">{b.data.title}</p>
                <p class="truncate text-dim" style="font-size: 0.65rem;">{b.data.author}</p>
              </a>
            ))}
          </div>
        </section>
      </>
    ) : null;
  })()}

  <!-- Quick links -->
  <hr class="section-divider" />
  <section class="py-8 text-center">
    <a href={`${base}categories/`} class="btn btn-outline">Explore Categories</a>
  </section>
</Layout>
