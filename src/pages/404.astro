---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import stats from '../data/stats.json';
import { toSlug } from '../utils/formatting';

const base = import.meta.env.BASE_URL;
const books = await getCollection('books');
const categories = [...new Set(books.map(b => b.data.category))].sort();
const topCategories = categories.slice(0, 8);
---

<Layout title="Not Found">
  <div class="text-center py-12">
    <p class="heading-xl text-dim mb-4">404</p>
    <h1 class="heading-lg mb-4">Lost in the Stacks</h1>
    <p class="text-muted mb-8">This book isn't on the shelf — but there are {stats.total_books.toLocaleString()} others to get lost in.</p>
    <div class="flex flex-wrap justify-center gap-3 mb-8">
      <a href={base} class="btn">Go home</a>
      <a href={`${base}browse/`} class="btn btn-outline">Browse all books</a>
    </div>

    <div class="max-w-2xl mx-auto">
      <p class="text-sm text-dim mb-4">Or explore a category:</p>
      <div class="flex flex-wrap justify-center gap-2">
        {topCategories.map(cat => (
          <a href={`${base}categories/${toSlug(cat)}/`} class="meta-tag">
            {cat}
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>
