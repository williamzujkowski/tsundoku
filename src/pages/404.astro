---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Not Found">
  <div class="text-center py-24">
    <p class="text-7xl font-bold text-gray-800 mb-4">404</p>
    <h1 class="text-2xl font-bold text-white mb-3">Page not found</h1>
    <p class="text-gray-400 mb-8">This book isn't on the shelf.</p>
    <a href={base} class="inline-flex items-center justify-center rounded-lg bg-purple-600 hover:bg-purple-500 text-white font-semibold px-6 py-2.5 text-sm transition-colors">
      Go home
    </a>
  </div>
</Layout>
