---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { priorityLabel, priorityClass, toSlug, statusLabel, statusClass } from '../../utils/formatting';
import ShareButton from '../../components/ShareButton.svelte';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.data.slug },
    props: { book: book.data },
  }));
}

const base = import.meta.env.BASE_URL;
const { book } = Astro.props;

const allBooks = await getCollection('books');
const sameAuthor = allBooks
  .filter(b => b.data.author === book.author && b.data.slug !== book.slug)
  .map(b => b.data)
  .sort((a, b) => a.priority - b.priority || a.title.localeCompare(b.title));

const sameCategory = allBooks
  .filter(b => b.data.category === book.category && b.data.slug !== book.slug)
  .map(b => b.data)
  .sort((a, b) => a.priority - b.priority || a.title.localeCompare(b.title))
  .slice(0, 12);

const categorySlug = toSlug(book.category);
---

<Layout title={book.title} description={book.description || `${book.title} by ${book.author} — ${book.category}`} image={book.cover_url_large || book.cover_url}>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Book",
    "name": book.title,
    "author": { "@type": "Person", "name": book.author },
    ...(book.description ? { "description": book.description } : {}),
    ...(book.isbn ? { "isbn": book.isbn } : {}),
    ...(book.cover_url ? { "image": book.cover_url_large || book.cover_url } : {}),
    ...(book.first_published ? { "datePublished": String(book.first_published) } : {}),
    ...(book.pages ? { "numberOfPages": book.pages } : {}),
    ...(book.language ? { "inLanguage": book.language } : {}),
  })} />
  <nav class="mb-6 text-sm text-gray-500">
    <a href={`${base}`} class="hover:text-white transition-colors">Home</a>
    <span class="mx-1">/</span>
    <a href={`${base}categories/${categorySlug}/`} class="hover:text-white transition-colors">{book.category}</a>
    <span class="mx-1">/</span>
    <span class="text-gray-400 truncate">{book.title}</span>
  </nav>

  <article class="max-w-4xl">
    <!-- Hero: cover + title -->
    <div class="flex flex-col sm:flex-row gap-6 sm:gap-8 mb-8">
      {book.cover_url ? (
        <div class="shrink-0">
          <img
            src={book.cover_url_large || book.cover_url}
            alt={`Cover of ${book.title}`}
            class="w-36 sm:w-48 rounded-lg shadow-lg shadow-black/40 border border-gray-800"
            loading="eager"
          />
        </div>
      ) : (
        <div class="shrink-0 w-36 sm:w-48 h-52 sm:h-72 rounded-lg bg-gradient-to-br from-purple-900/40 to-gray-900 border border-gray-800 flex items-center justify-center">
          <span class="text-4xl text-gray-700">📖</span>
        </div>
      )}

      <div class="flex-1 min-w-0">
        <span class={`inline-block text-xs px-3 py-1 rounded-full mb-3 ${priorityClass(book.priority)}`}>
          {priorityLabel(book.priority)}
        </span>
        <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold text-white mb-2">{book.title}</h1>
        <p class="text-lg text-gray-400 mb-3">by {book.author === 'Unknown' ? (
          <span class="text-gray-500">{book.author}</span>
        ) : (
          <a href={`${base}authors/${toSlug(book.author)}/`} class="text-purple-400 hover:text-purple-300 transition-colors">{book.author}</a>
        )}</p>

        <div class="mb-3 flex flex-wrap items-center gap-2">
          {book.reading_status && (
            <span class={`text-xs px-2.5 py-1 rounded-lg border ${statusClass(book.reading_status)}`}>
              {statusLabel(book.reading_status)}
            </span>
          )}
          {book.copyright_status === 'public_domain' && (
            <span class="text-xs px-2.5 py-1 rounded-lg border bg-emerald-900/30 border-emerald-700/40 text-emerald-300">
              Public Domain
            </span>
          )}
          {book.copyright_status === 'likely_public_domain' && (
            <span class="text-xs px-2.5 py-1 rounded-lg border bg-teal-900/30 border-teal-700/40 text-teal-300">
              Likely Public Domain
            </span>
          )}
          {book.status_notes && (
            <span class="text-xs text-gray-500 italic">{book.status_notes}</span>
          )}
        </div>

        {book.description && (
          <p class="text-gray-300 text-sm sm:text-base leading-relaxed mb-4">{book.description}</p>
        )}

        <div class="flex flex-wrap gap-2 text-xs">
          {book.first_published && (
            <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">
              First published: {book.first_published}
            </span>
          )}
          {book.pages && (
            <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">
              {book.pages} pages
            </span>
          )}
          {book.isbn && (
            <span class="px-2 py-1 rounded bg-gray-800 text-gray-400">
              ISBN: {book.isbn}
            </span>
          )}
        </div>
      </div>
    </div>

    <!-- Metadata card -->
    <div class="rounded-xl border border-gray-800 bg-gray-900 p-5 sm:p-6 mb-8">
      <dl class="grid grid-cols-2 sm:grid-cols-3 gap-4 text-sm">
        <div>
          <dt class="text-gray-500 mb-1">Category</dt>
          <dd>
            <a href={`${base}categories/${categorySlug}/`} class="text-white hover:text-purple-400 transition-colors">
              {book.category}
            </a>
          </dd>
        </div>
        <div>
          <dt class="text-gray-500 mb-1">Priority</dt>
          <dd class="text-white">{priorityLabel(book.priority)}</dd>
        </div>
        <div>
          <dt class="text-gray-500 mb-1">Author works</dt>
          <dd class="text-white">{sameAuthor.length + 1}</dd>
        </div>
        {book.language && (
          <div>
            <dt class="text-gray-500 mb-1">Language</dt>
            <dd class="text-white">{book.language}</dd>
          </div>
        )}
      </dl>

      {book.subjects && book.subjects.length > 0 && (
        <div class="mt-4 pt-4 border-t border-gray-800">
          <dt class="text-gray-500 text-sm mb-2">Subjects</dt>
          <div class="flex flex-wrap gap-1.5">
            {book.subjects.map(s => (
              <span class="text-xs px-2 py-1 rounded-full bg-gray-800 text-gray-400">{s}</span>
            ))}
          </div>
        </div>
      )}

      {/* Free reading/listening links */}
      {(book.gutenberg_url || book.hathitrust_url || book.librivox_url || book.standardebooks_url || book.archive_url) && (
        <div class="mt-4 pt-4 border-t border-gray-800 flex flex-wrap gap-2">
          {book.gutenberg_url && (
            <a href={book.gutenberg_read_url || book.gutenberg_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-lg bg-green-900/30 border border-green-700/40 text-green-300 hover:bg-green-900/50 px-4 py-2 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              Read on Gutenberg
            </a>
          )}
          {book.hathitrust_url && (
            <a href={book.hathitrust_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-lg bg-blue-900/30 border border-blue-700/40 text-blue-300 hover:bg-blue-900/50 px-4 py-2 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21" />
              </svg>
              Read on HathiTrust
            </a>
          )}
          {book.librivox_url && (
            <a href={book.librivox_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-lg bg-amber-900/30 border border-amber-700/40 text-amber-300 hover:bg-amber-900/50 px-4 py-2 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
              </svg>
              Listen on LibriVox
            </a>
          )}
          {book.standardebooks_url && (
            <a href={book.standardebooks_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-lg bg-purple-900/30 border border-purple-700/40 text-purple-300 hover:bg-purple-900/50 px-4 py-2 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3" />
              </svg>
              Standard Ebooks
            </a>
          )}
          {book.archive_url && (
            <a href={book.archive_url} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 rounded-lg bg-blue-900/30 border border-blue-700/40 text-blue-300 hover:bg-blue-900/50 px-4 py-2 text-sm font-medium transition-colors">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21" />
              </svg>
              Internet Archive
            </a>
          )}
        </div>
      )}

      {/* Share + External links */}
      <div class="mt-4 pt-4 border-t border-gray-800 flex flex-wrap gap-3 items-center">
        <ShareButton client:idle title={`${book.title} by ${book.author}`} url={Astro.site ? new URL(`${base}books/${book.slug}/`, Astro.site).href : ''} />
        {book.gutenberg_url && (
          <a href={book.gutenberg_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-green-400 hover:text-green-300 transition-colors">
            Project Gutenberg
          </a>
        )}
        {book.open_library_url && (
          <a href={book.open_library_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            Open Library
          </a>
        )}
        {book.google_books_url && (
          <a href={book.google_books_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            Google Books
          </a>
        )}
        <a href={`https://www.goodreads.com/search?q=${encodeURIComponent(book.title + ' ' + book.author)}`}
           target="_blank" rel="noopener noreferrer"
           class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
          Goodreads
        </a>
        {book.worldcat_url && (
          <a href={book.worldcat_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            WorldCat
          </a>
        )}
        {!book.worldcat_url && book.isbn && (
          <a href={`https://www.worldcat.org/isbn/${book.isbn}`}
             target="_blank" rel="noopener noreferrer"
             class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            WorldCat
          </a>
        )}
        {book.hathitrust_url && (
          <a href={book.hathitrust_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-blue-400 hover:text-blue-300 transition-colors">
            HathiTrust
          </a>
        )}
        {book.librivox_url && (
          <a href={book.librivox_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-amber-400 hover:text-amber-300 transition-colors">
            LibriVox
          </a>
        )}
        {book.standardebooks_url && (
          <a href={book.standardebooks_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            Standard Ebooks
          </a>
        )}
        {book.archive_url && (
          <a href={book.archive_url} target="_blank" rel="noopener noreferrer"
             class="text-sm text-blue-400 hover:text-blue-300 transition-colors">
            Internet Archive
          </a>
        )}
      </div>
    </div>

    <!-- More by author -->
    {sameAuthor.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-white mb-4">More by {book.author}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {sameAuthor.slice(0, 6).map(b => (
            <a href={`${base}books/${b.slug}/`}
               class="rounded-xl border border-gray-800 bg-gray-900 p-4 hover:border-purple-800/60 transition-colors flex gap-3 items-start">
              {b.cover_url ? (
                <img src={b.cover_url} alt={b.title} class="w-10 h-14 rounded object-cover shrink-0" loading="lazy" />
              ) : (
                <div class="w-10 h-14 rounded bg-gray-800 shrink-0 flex items-center justify-center text-gray-700 text-xs" aria-hidden="true">📖</div>
              )}
              <div class="min-w-0">
                <h3 class="text-white text-sm font-medium line-clamp-2">{b.title}</h3>
                <span class={`text-[11px] ${b.priority === 1 ? 'text-purple-400' : 'text-gray-500'}`}>
                  {priorityLabel(b.priority)}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More in category -->
    {sameCategory.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-bold text-white mb-4">More in {book.category}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          {sameCategory.slice(0, 6).map(b => (
            <a href={`${base}books/${b.slug}/`}
               class="rounded-xl border border-gray-800 bg-gray-900 p-4 hover:border-purple-800/60 transition-colors flex gap-3 items-start">
              {b.cover_url ? (
                <img src={b.cover_url} alt={b.title} class="w-10 h-14 rounded object-cover shrink-0" loading="lazy" />
              ) : (
                <div class="w-10 h-14 rounded bg-gray-800 shrink-0 flex items-center justify-center text-gray-700 text-xs" aria-hidden="true">📖</div>
              )}
              <div class="min-w-0">
                <h3 class="text-white text-sm font-medium line-clamp-2">{b.title}</h3>
                <p class="text-gray-500 text-xs">{b.author}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-3">
          <a href={`${base}categories/${categorySlug}/`} class="text-sm text-purple-400 hover:text-purple-300 transition-colors">
            View all {book.category} books →
          </a>
        </div>
      </section>
    )}
  </article>

  <div class="mt-8 pt-6 border-t border-gray-800">
    <a href={`${base}browse/`} class="text-sm text-gray-400 hover:text-white transition-colors">
      ← Back to browse
    </a>
  </div>
</Layout>
