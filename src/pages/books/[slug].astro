---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { priorityLabel, priorityClass, toSlug, statusLabel, statusClass, parseAuthors, languageLabel, formatYear } from '../../utils/formatting';
import ShareButton from '../../components/ShareButton.svelte';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.data.slug },
    props: { book: book.data },
  }));
}

const base = import.meta.env.BASE_URL;
const { book } = Astro.props;

const allBooks = await getCollection('books');
const sameAuthor = allBooks
  .filter(b => b.data.author === book.author && b.data.slug !== book.slug)
  .map(b => b.data)
  .sort((a, b) => a.priority - b.priority || a.title.localeCompare(b.title));

const sameAuthorSlugs = new Set(sameAuthor.map(b => b.slug));
const sameCategory = allBooks
  .filter(b => b.data.category === book.category && b.data.slug !== book.slug && !sameAuthorSlugs.has(b.data.slug))
  .map(b => b.data)
  .sort((a, b) => a.priority - b.priority || a.title.localeCompare(b.title))
  .slice(0, 12);

const categorySlug = toSlug(book.category);

// Virtual shelf — books physically adjacent to this one in LCC order.
// The strongest single library-feel structural change per #129. Sort
// the catalog by Library of Congress call number; take 2 books before
// and 2 books after the current book. Only renders for books with an
// LCC, since the metaphor doesn't work without a call-number anchor.
//
// OL stores LCC strings with sort padding ("PR-6029.00000000.R8 Ni2");
// `lccDisplay` strips that to a human-readable form ("PR6029 R8 Ni2").
function lccSortKey(lcc: string): [string, number, string] {
  const m = lcc.match(/^([A-Z]+)-?(\d*)(.*)$/);
  if (!m) return [lcc, 0, ''];
  return [m[1], parseInt(m[2] || '0', 10), m[3] || ''];
}
function compareLcc(a: string, b: string): number {
  const ka = lccSortKey(a);
  const kb = lccSortKey(b);
  if (ka[0] !== kb[0]) return ka[0].localeCompare(kb[0]);
  if (ka[1] !== kb[1]) return ka[1] - kb[1];
  return ka[2].localeCompare(kb[2]);
}
function lccDisplay(lcc: string): string {
  // OL pads LCC for sorting — strip leading hyphen between class+number,
  // collapse all-zero fractional padding, normalize internal whitespace.
  return lcc
    .replace(/^([A-Z]+)-(\d)/, '$1$2')
    .replace(/\.0+(?=\D|$)/g, '')
    .replace(/\s+/g, ' ')
    .trim();
}

const currentLcc = book.lcc?.[0] ?? null;
let shelfNeighbors: Array<{ slug: string; title: string; author: string; cover_url?: string; lcc: string }> = [];
if (currentLcc) {
  const shelf = allBooks
    .map(b => b.data)
    .filter(b => b.lcc && b.lcc[0])
    .map(b => ({ slug: b.slug, title: b.title, author: b.author, cover_url: b.cover_url, lcc: b.lcc![0] }))
    .sort((a, b) => compareLcc(a.lcc, b.lcc));
  const idx = shelf.findIndex(b => b.slug === book.slug);
  if (idx >= 0) {
    const before = shelf.slice(Math.max(0, idx - 2), idx);
    const after = shelf.slice(idx + 1, idx + 3);
    shelfNeighbors = [...before, ...after];
  }
}
---

<Layout title={book.title} description={book.description || `${book.title} by ${book.author} — ${book.category}`} image={book.cover_url_large || book.cover_url}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Book",
    "name": book.title,
    "author": { "@type": "Person", "name": book.author },
    ...(book.description ? { "description": book.description } : {}),
    ...(book.cover_url ? { "image": book.cover_url_large || book.cover_url } : {}),
    ...(book.isbn ? { "isbn": book.isbn } : {}),
    ...(book.pages ? { "numberOfPages": book.pages } : {}),
    ...(book.language ? { "inLanguage": book.language } : {}),
    ...(book.translator ? { "translator": { "@type": "Person", "name": book.translator } } : {}),
    ...(book.first_published !== undefined || book.original_title || book.original_language ? {
      "exampleOfWork": {
        "@type": "Book",
        ...(book.original_title ? { "name": book.original_title } : { "name": book.title }),
        "author": { "@type": "Person", "name": book.author },
        ...(book.first_published !== undefined ? { "datePublished": String(book.first_published) } : {}),
        ...(book.original_language ? { "inLanguage": book.original_language } : {}),
      }
    } : {}),
  })} />
  <nav class="breadcrumb">
    <a href={`${base}`}>Home</a>
    <span class="breadcrumb-sep">/</span>
    <a href={`${base}categories/${categorySlug}/`}>{book.category}</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current truncate">{book.title}</span>
  </nav>

  <article>
    <!-- Hero: cover + title -->
    <div class="book-detail-layout">
      {book.cover_url ? (
        <div class="book-detail-cover-wrap">
          <img
            src={book.cover_url_large || book.cover_url}
            alt={`Cover of ${book.title}`}
            class="book-detail-cover"
            loading="eager"
            transition:name={`cover-${book.slug}`}
          />
          {currentLcc && (
            <span class="book-spine-label" title="Library of Congress call number">
              {lccDisplay(currentLcc)}
            </span>
          )}
        </div>
      ) : (
        <div class="book-detail-cover-placeholder">📖</div>
      )}

      <div class="book-detail-info">
        <span class={`${priorityClass(book.priority)} mb-4`}>
          {priorityLabel(book.priority)}
        </span>
        <h1 class="heading-xl mb-2">{book.title}</h1>
        <p class="text-muted mb-4">by {book.author === 'Unknown' ? (
          <span class="text-dim">{book.author}</span>
        ) : (() => {
          const parsed = parseAuthors(book.author);
          if (!parsed.isJoint) {
            return <a href={`${base}authors/${toSlug(book.author)}/`} class="ext-link">{book.author}</a>;
          }
          return parsed.parts.map((part, i) => (
            <>
              {i > 0 && <span class="text-dim"> · </span>}
              <a href={`${base}authors/${toSlug(part)}/`} class="ext-link">{part}</a>
            </>
          ));
        })()}</p>

        <div class="flex flex-wrap items-center gap-2 mb-4">
          {book.reading_status && (
            <span class={statusClass(book.reading_status)}>
              {statusLabel(book.reading_status)}
            </span>
          )}
          {book.copyright_status === 'public_domain' && (
            <span class="status-badge status-read">Public Domain</span>
          )}
          {book.copyright_status === 'likely_public_domain' && (
            <span class="status-badge stat-badge-blue">Likely Public Domain</span>
          )}
          {book.series && (
            <span class="status-badge stat-badge-blue">
              {book.series.name}{book.series.position ? ` #${book.series.position}` : ''}
            </span>
          )}
        </div>

        {book.original_title && book.original_title.toLowerCase() !== book.title.toLowerCase() && (
          <p class="text-dim text-sm mb-3">
            Originally <i lang={book.original_language || undefined}>{book.original_title}</i>
            {book.original_language && book.original_language !== 'eng' && (
              <span> · {languageLabel(book.original_language)}</span>
            )}
          </p>
        )}

        {book.description && (
          <p class="text-muted text-sm mb-4 prose-text">{book.description}</p>
        )}

        <div class="flex flex-wrap gap-2">
          {book.first_published !== undefined && (
            <span class="meta-tag">
              First published {formatYear(book.first_published, book.first_published_circa)}
            </span>
          )}
          {book.original_publisher && (
            <span class="meta-tag">{book.original_publisher}</span>
          )}
          {book.pages && (
            <span class="meta-tag">{book.pages} pages</span>
          )}
        </div>

        {book.awards && book.awards.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-3">
            {book.awards.slice(0, 6).map(a => (
              <span class="meta-tag" title={a.year ? `${a.name} (${a.year})` : a.name}>
                {a.name}{a.year ? ` (${a.year})` : ''}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Metadata card -->
    <div class="card card-padded-lg mb-8">
      <dl class="grid grid-2 md-grid-3 gap-4 text-sm">
        <div>
          <dt class="text-dim mb-2">Category</dt>
          <dd><a href={`${base}categories/${categorySlug}/`} class="ext-link">{book.category}</a></dd>
        </div>
        <div>
          <dt class="text-dim mb-2">Priority</dt>
          <dd>{priorityLabel(book.priority)}</dd>
        </div>
        <div>
          <dt class="text-dim mb-2">Author works</dt>
          <dd>{sameAuthor.length + 1}</dd>
        </div>
        {book.editions_count && (
          <div>
            <dt class="text-dim mb-2">Editions known</dt>
            <dd>{book.editions_count}</dd>
          </div>
        )}
      </dl>

      {/* Classification — DDC + LCC + curated subject_facet */}
      {((book.ddc && book.ddc.length > 0) || (book.lcc && book.lcc.length > 0) || (book.subject_facet && book.subject_facet.length > 0)) && (
        <div class="detail-section">
          <dt class="text-dim text-sm mb-2">Classification</dt>
          <dd class="flex flex-wrap gap-2 text-xs">
            {book.ddc && book.ddc.length > 0 && (
              <span class="meta-tag text-mono" title="Dewey Decimal">DDC {book.ddc[0]}</span>
            )}
            {book.lcc && book.lcc.length > 0 && (
              <span class="meta-tag text-mono" title="Library of Congress">LCC {book.lcc[0]}</span>
            )}
            {book.subject_facet && book.subject_facet.slice(0, 8).map(s => (
              <span class="meta-tag">{s}</span>
            ))}
          </dd>
        </div>
      )}

      {/* This edition — what the user is actually reading. Distinct from
          the work-level metadata above (year, original title). */}
      {(book.isbn || book.language || book.translator || (book.first_edition_isbn !== undefined && book.first_edition_isbn !== null && book.first_edition_isbn !== book.isbn)) && (
        <div class="detail-section">
          <dt class="text-dim text-sm mb-2">This edition</dt>
          <dd class="flex flex-wrap gap-3 text-xs items-center">
            {book.isbn && (
              <span class="text-mono">ISBN {book.isbn}</span>
            )}
            {book.language && (
              <span>{languageLabel(book.language)}</span>
            )}
            {book.translator && (
              <span>Translated by {book.translator}</span>
            )}
            {book.first_edition_isbn !== undefined && book.first_edition_isbn !== null && book.first_edition_isbn !== book.isbn && (
              <span class="text-dim text-mono">First-edition ISBN: {book.first_edition_isbn}</span>
            )}
          </dd>
        </div>
      )}


      {(book.gutenberg_url || book.hathitrust_url || book.librivox_url) && (
        <div class="detail-section flex flex-wrap gap-2">
          {book.gutenberg_url && (
            <a href={book.gutenberg_read_url || book.gutenberg_url} target="_blank" rel="noopener noreferrer"
               class="resource-btn resource-btn-gutenberg">
              <svg class="icon-sm" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
              </svg>
              Read on Gutenberg
            </a>
          )}
          {book.hathitrust_url && (
            <a href={book.hathitrust_url} target="_blank" rel="noopener noreferrer"
               class="resource-btn resource-btn-hathitrust">
              <svg class="icon-sm" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21" />
              </svg>
              Read on HathiTrust
            </a>
          )}
          {book.librivox_url && (
            <a href={book.librivox_url} target="_blank" rel="noopener noreferrer"
               class="resource-btn resource-btn-librivox">
              <svg class="icon-sm" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.114 5.636a9 9 0 0 1 0 12.728M16.463 8.288a5.25 5.25 0 0 1 0 7.424M6.75 8.25l4.72-4.72a.75.75 0 0 1 1.28.53v15.88a.75.75 0 0 1-1.28.53l-4.72-4.72H4.51c-.88 0-1.704-.507-1.938-1.354A9.009 9.009 0 0 1 2.25 12c0-.83.112-1.633.322-2.396C2.806 8.756 3.63 8.25 4.51 8.25H6.75Z" />
              </svg>
              Listen on LibriVox
            </a>
          )}
        </div>
      )}

      <div class="detail-section flex flex-wrap gap-3 items-center">
        <ShareButton client:idle title={`${book.title} by ${book.author}`} url={Astro.site ? new URL(`${base}books/${book.slug}/`, Astro.site).href : ''} />
        {book.gutenberg_url && <a href={book.gutenberg_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">Project Gutenberg</a>}
        {book.open_library_url && <a href={book.open_library_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">Open Library</a>}
        {book.google_books_url && <a href={book.google_books_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">Google Books</a>}
        <a href={`https://www.goodreads.com/search?q=${encodeURIComponent(book.title + ' ' + book.author)}`} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">Goodreads</a>
        {book.worldcat_url && <a href={book.worldcat_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">WorldCat</a>}
        {!book.worldcat_url && book.isbn && <a href={`https://www.worldcat.org/isbn/${book.isbn}`} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">WorldCat</a>}
        {book.hathitrust_url && <a href={book.hathitrust_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">HathiTrust</a>}
        {book.librivox_url && <a href={book.librivox_url} target="_blank" rel="noopener noreferrer" class="ext-link text-sm">LibriVox</a>}
      </div>
    </div>

    <!-- On the Same Shelf — LCC-adjacent neighbors -->
    {shelfNeighbors.length > 0 && currentLcc && (
      <section class="mb-8">
        <h2 class="heading-md mb-2">On the Same Shelf</h2>
        <p class="text-dim text-sm mb-4">
          Books one call-number away from <span class="text-mono">{lccDisplay(currentLcc)}</span> in the LCC stacks.
        </p>
        <div class="grid sm-grid-2 md-grid-4 gap-3">
          {shelfNeighbors.map(b => (
            <a href={`${base}books/${b.slug}/`} class="card related-book">
              {b.cover_url ? (
                <img src={b.cover_url} alt={`Cover of ${b.title}`} class="related-book-cover" loading="lazy" />
              ) : (
                <div class="book-thumb-placeholder" aria-hidden="true">📖</div>
              )}
              <div class="book-card-body">
                <span class="text-xs text-dim text-mono">{lccDisplay(b.lcc)}</span>
                <h3 class="text-sm font-bold line-clamp-2">{b.title}</h3>
                <p class="text-xs text-dim line-clamp-1">{b.author}</p>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More by author -->
    {sameAuthor.length > 0 && (
      <section class="mb-8">
        <h2 class="heading-md mb-4">More by {book.author}</h2>
        <div class="grid sm-grid-2 md-grid-3 gap-3">
          {sameAuthor.slice(0, 6).map(b => (
            <a href={`${base}books/${b.slug}/`} class="card related-book">
              {b.cover_url ? (
                <img src={b.cover_url} alt={`Cover of ${b.title}`} class="related-book-cover" loading="lazy" transition:name={`cover-${b.slug}`} />
              ) : (
                <div class="book-thumb-placeholder" aria-hidden="true">📖</div>
              )}
              <div class="book-card-body">
                <h3 class="text-sm font-bold line-clamp-2">{b.title}</h3>
                <span class={`text-xs ${b.priority === 1 ? 'stat-number-pink' : 'text-dim'}`}>
                  {priorityLabel(b.priority)}
                </span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- More in category -->
    {sameCategory.length > 0 && (
      <section class="mb-8">
        <h2 class="heading-md mb-4">More in {book.category}</h2>
        <div class="grid sm-grid-2 md-grid-3 gap-3">
          {sameCategory.slice(0, 6).map(b => (
            <a href={`${base}books/${b.slug}/`} class="card related-book">
              {b.cover_url ? (
                <img src={b.cover_url} alt={`Cover of ${b.title}`} class="related-book-cover" loading="lazy" transition:name={`cover-${b.slug}`} />
              ) : (
                <div class="book-thumb-placeholder" aria-hidden="true">📖</div>
              )}
              <div class="book-card-body">
                <h3 class="text-sm font-bold line-clamp-2">{b.title}</h3>
                <p class="text-xs text-dim">{b.author}</p>
              </div>
            </a>
          ))}
        </div>
        <div class="mt-2">
          <a href={`${base}categories/${categorySlug}/`} class="ext-link text-sm">
            View all {book.category} books →
          </a>
        </div>
      </section>
    )}

    <hr class="section-divider" />
    <a href={`${base}browse/`} class="ext-link text-sm text-muted">← Back to browse</a>
  </article>
</Layout>
