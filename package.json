    "test:watch": "vitest",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "astro": "^7.1.3",
    "remarque-tokens": "^0.17.0",
    "svelte": "^5.56.7",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  },
  "overrides": {
    "yaml": ">=2.8.3",
    "postcss": ">=8.5.10",
    "fast-uri": "^4.1.1"
  }
