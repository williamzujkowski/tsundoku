{
  "name": "tsundoku",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "stats": "python3 scripts/generate-stats.py",
